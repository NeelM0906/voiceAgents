{
  "name": "voice-agents",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc --noEmit -p tsconfig.json",
    "dev": "concurrently -k -n worker,api,inngest -c blue,magenta,yellow \"pnpm dev:worker\" \"pnpm dev:api\" \"pnpm dev:inngest\"",
    "dev:worker": "tsx --env-file=.env.local src/agent.ts dev",
    "dev:api": "tsx watch src/api.ts",
    "dev:inngest": "npx inngest-cli@latest dev -u http://localhost:${API_PORT:-8787}/api/inngest",
    "download-files": "livekit-agents download-files",
    "ingest": "tsx src/cli/ingest.ts",
    "eval": "tsx src/cli/eval.ts",
    "embed:reindex": "tsx src/cli/ingest.ts --reindex",
    "start": "pnpm start:worker",
    "start:worker": "node dist/agent.js start",
    "start:api": "node dist/api.js"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.3",
    "@livekit/agents": "^1.4.4",
    "@livekit/agents-plugin-openai": "^1.4.4",
    "@livekit/agents-plugin-silero": "^1.4.4",
    "@supabase/supabase-js": "^2.106.1",
    "cohere-ai": "^8.0.0",
    "fast-glob": "^3.3.3",
    "hono": "^4.12.22",
    "inngest": "^4.4.0",
    "openai": "^6.39.0",
    "pino": "^10.3.1",
    "twilio": "^6.0.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "concurrently": "^9.2.1",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@ffmpeg-installer/linux-x64",
      "esbuild",
      "onnxruntime-node",
      "protobufjs",
      "sharp"
    ]
  },
  "packageManager": "pnpm@10.30.3"
}
