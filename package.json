{
  "name": "voice-agents",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc --noEmit -p tsconfig.json",
    "dev": "tsx --env-file=.env.local src/agent.ts dev",
    "download-files": "livekit-agents download-files",
    "start": "node dist/agent.js start"
  },
  "dependencies": {
    "@livekit/agents": "^1.4.4",
    "@livekit/agents-plugin-openai": "^1.4.4",
    "@livekit/agents-plugin-silero": "^1.4.4",
    "pino": "^10.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@ffmpeg-installer/linux-x64",
      "esbuild",
      "onnxruntime-node",
      "protobufjs",
      "sharp"
    ]
  },
  "packageManager": "pnpm@10.30.3"
}
